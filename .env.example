# AstraCore Access Control — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Database ────────────────────────────────────────────────────────────────
# Double underscore (__) is the .NET hierarchy separator.
# This overrides ConnectionStrings.DefaultConnection in appsettings.json.
# 
# SQL Server with SQL authentication:
# ConnectionStrings__DefaultConnection=Server=HOST\INSTANCE;Database=DB_NAME;User Id=USER;Password=PASSWORD;TrustServerCertificate=True;
#
# SQL Server with Windows authentication:
# ConnectionStrings__DefaultConnection=Server=HOST\INSTANCE;Database=DB_NAME;Trusted_Connection=True;TrustServerCertificate=True;

ConnectionStrings__DefaultConnection=Server=HOST\INSTANCE;Database=DB_NAME;User Id=DB_USER;Password=DB_PASSWORD;TrustServerCertificate=True;
